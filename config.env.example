# Leave blank to use ~/brain, or set an absolute path.
BRAIN_REPO=
CIRCLEBACK_GBRAIN_PORT=3137

# Paste the signing secret from Circleback's webhook automation step.
# Keep CIRCLEBACK_REQUIRE_SIGNATURE=true for production.
CIRCLEBACK_WEBHOOK_SECRET=
CIRCLEBACK_REQUIRE_SIGNATURE=true

# Set false if you do not have OPENAI_API_KEY yet.
GBRAIN_EMBED_ON_INGEST=true
CIRCLEBACK_RECONCILE_DAYS=2
CIRCLEBACK_CLI_RECONCILE_ENABLED=false
CIRCLEBACK_NIGHTLY_BACKFILL_DAYS=14
GBRAIN_OPENCLAW_NIGHTLY_ATTEMPTS=3
GBRAIN_OPENCLAW_NIGHTLY_RETRY_SECONDS=45
GBRAIN_OPENCLAW_NIGHTLY_TIMEOUT_SECONDS=1800

# Optional but recommended: Cloudflare Worker durable inbox.
# Circleback posts to the Worker; this Mac pulls pending items privately.
CIRCLEBACK_WORKER_URL=
CIRCLEBACK_WORKER_PENDING_PATH=/api/inbox/pending
CIRCLEBACK_WORKER_ACK_PATH=/api/inbox/ack
CIRCLEBACK_WORKER_AUTH_HEADER=x-control-room-secret
CONTROL_ROOM_PULL_SECRET=

# Optional, only if not already in ~/.zshrc or your launch environment.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
